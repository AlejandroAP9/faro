# ─────────────────────────────────────────────────────────────────────────────
# Raíz — variables de entorno. Copia este archivo a .env.local y rellena.
# .env.local esta gitignored; este .env.example NO (documenta lo esperado).
# Nunca committees valores reales. Regla: .claude/rules/secrets-env.md
# ─────────────────────────────────────────────────────────────────────────────

# === CORE (requerido) ===

# Supabase (Auth + DB + Storage). Panel del proyecto → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only, NUNCA al cliente

# AI Engine (Vercel AI SDK v5 + OpenRouter)
OPENROUTER_API_KEY=

# URL publica del sitio (para callbacks de auth, emails, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Allowlist de editores del backend de conocimiento (/admin). Coma-separado.
# Solo estos emails pueden crear/editar Pasos, rutas y playbooks de Pista.
PISTA_EDITOR_EMAILS=

# === OPCIONAL — solo si usas la skill correspondiente ===

# Emails transaccionales (skill: add-emails → Resend)
# RESEND_API_KEY=

# Pagos (skill: add-payments). Ajusta a tu proveedor. Ej. Mercado Pago (CLP):
# MP_ACCESS_TOKEN=
# MP_WEBHOOK_SECRET=

# Push / PWA (skill: add-mobile → Web Push VAPID)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Cron / trabajos programados (skill: add-cron). Genera uno: openssl rand -hex 32
# Vercel lo manda como Authorization: Bearer <CRON_SECRET>; la ruta lo verifica.
# CRON_SECRET=
